{
  "name": "anthropic-tool-call-sequence",
  "format": "sequence",
  "sequence": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/messages",
        "headers": {
          "anthropic-version": "2023-06-01",
          "content-type": "application/json",
          "x-api-key": "{{OPENCLAW_TOKEN}}"
